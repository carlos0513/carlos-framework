<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yunjin.org.mapper.LabelMapper">
    <resultMap type="com.yunjin.org.pojo.entity.Label" id="baseMap">
                <id column="id" property="id"/>
                <result column="name" property="name"/>
                <result column="code" property="code"/>
                <result column="type_id" property="typeId"/>
                <result column="sort" property="sort"/>
                <result column="is_hidden" property="hidden"/>
                <result column="create_by" property="createBy"/>
                <result column="create_time" property="createTime"/>
                <result column="update_by" property="updateBy"/>
                <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="listByIdsIncludeDeleted" resultType="com.yunjin.org.pojo.entity.Label">
        select * from bbt_label where id in
        <foreach item="id" collection="ids" separator="," open="(" close=")" index="">
            #{id}
        </foreach>
    </select>

    <select id="getByIdIncludeDeleted" resultMap="baseMap">
        select * from bbt_label where id = #{id}
    </select>
</mapper>
