#!/usr/bin/env groovy

/* ========== 可手动触发参数 ========== */
properties([
        parameters([
                choice(
                        name: 'DEPLOY_ENV',
                        choices: ['开发环境', '测试环境', '演示环境', '自定义'],
                        description: '发布环境'
                ),
                string(
                        name: 'NAMESPACE',
                        description: '要部署到的namespace, 自定义时需填写'
                ),
                text(
                        name: 'ENV',
                        defaultValue: '''

    			        -
    			          name: NACOS_USERNAME
    			          value: bbt
    			        -
    			          name: NACOS_PASSWORD
    			          value: bbt@123456
    			        -
    			          name: NACOS_NAMESPACE
    			          value: #NAMESPACE
    			        -
    			          name: NACOS_ADDR
    			          value: 192.168.1.169:18848
    			        -
    			          name: NACOS_GROUP
    			          value: DEFAULT_GROUP''',
                        description: '环境变量'
                ),
                choice(
                        name: 'IMAGE_TAG',
                        choices: ['Alpha', 'Beat', 'Release', 'Demo'],
                        description: '镜像版本，自定义时必填'
                ),
                string(
                        name: 'PROJECT_NAME',
                        defaultValue: 'carlos-szt',
                        description: '项目名'
                ),
                string(
                        name: 'HARBOR_URL',
                        defaultValue: '192.168.1.221',
                        description: 'harbor地址'
                ),
        ])
])

// 返回 [tag: xxx, namespace: xxx]
def calcMeta() {
    switch (params.DEPLOY_ENV) {
        case '开发环境':
            return [tag: 'Alpha', namespace: 'carlos-szt-feature']
        case '测试环境':
            return [tag: 'Beta', namespace: 'carlos-szt-test']
        case '演示环境':
            return [tag: 'Release', namespace: 'carlos-szt-demo']
        case 'custom':
            def t = params.IMAGE_TAG?.trim()
            def n = params.NAMESPACE?.trim()
            if (!t || !n) error('custom 模式下 CUSTOM_TAG 和 CUSTOM_NAMESPACE 都必须填写')
            return [tag: t, namespace: n]
        default:   // test/staging/prod 等
            error('参数DEPLOY_ENV不合法！')
    }
}
// 再包一层函数调用，满足 Jenkins 语法
def imageTag() {
    def date = new Date().format('yyyyMMddHHmm', TimeZone.getTimeZone('Asia/Shanghai'))
    def baseTag = calcMeta().tag          // 你原来的 alpha/dev-123 等
    return "${baseTag}-${date}"
}

def nameSpace() { return calcMeta().namespace }


/* ========== 常量 ========== */
def repoUrl = scm.userRemoteConfigs[0].url
def APP_NAME = "${repoUrl.tokenize('/').last().replace('.git', '')}" // 仓库名即服务名
def REGISTRY = params.HARBOR_URL
def PROJECT = params.PROJECT_NAME

pipeline {
    options {
        timeout(time: 30, unit: 'MINUTES')   // 超时时间15分钟
        buildDiscarder(
                logRotator(
                        daysToKeepStr: '7',      // 保留 7 天内
                        numToKeepStr: '10',      // 最多 20 条
                        artifactDaysToKeepStr: '3',  // 工件只留 3 天
                        artifactNumToKeepStr: '5'    // 工件最多 5 份
                )
        )
    }
    agent {
        kubernetes {
            yaml """
apiVersion: "v1"
kind: "Pod"
metadata:
  labels:
    jenkins: "slave"
  namespace: "devops"
spec:
  activeDeadlineSeconds: 1800
  containers:
    -
      name: "jnlp"
      image: "harbor01.carlos.com/library/jenkins/inbound-agent:alpine"
      imagePullPolicy: "IfNotPresent"
      securityContext:
        privileged: true
      tty: false
    -
      name: "maven"
      resources:
        requests: { cpu: "2", memory: "2Gi" }
        limits: { cpu: "4", memory: "4Gi" }
      tty: true
      command: [ 'cat' ]
      env:
        -
          name: "MAVEN_OPTS"
          value: "-Xmx2g -XX:+UseG1GC"
      image: "harbor01.carlos.com/library/maven:3.8.5-openjdk-17"
      imagePullPolicy: "IfNotPresent"
      volumeMounts:
        -
          mountPath: "/root/.m2"
          name: maven-cache
          readOnly: false
        -
          name: docker-sock
          mountPath: /var/run/docker.sock
    -
      name: "docker"
      resources:
        requests: { cpu: "1", memory: "1Gi" }
        limits: { cpu: "2", memory: "2Gi" }
      image: "harbor01.carlos.com/library/docker:19.03.8-dind"
      imagePullPolicy: "IfNotPresent"
      securityContext:
        privileged: true
      tty: false
      volumeMounts:
        -
          mountPath: "/etc/docker/daemon.json"
          name: "volume-0"
          readOnly: false
        -
          name: docker-storage
          mountPath: /var/lib/docker
    -
      name: "kubectl"
      image: "harbor01.carlos.com/library/bitnami/kubectl:latest"
      imagePullPolicy: "IfNotPresent"
      command: [ 'cat' ]
      tty: true
  volumes:
    -
      name: maven-cache
      hostPath: { path: "/home/jenkins/agent/.m2", type: DirectoryOrCreate }
    -
      name: docker-sock
      hostPath: { path: /var/run/docker.sock }
    -
      name: docker-storage
      emptyDir: { }
    -
      hostPath:
        path: "/etc/docker/daemon.json"
      name: "volume-0"

"""
        }
    }

    environment {
        DOCKER_BUIDKIT = '0'
        IMAGE_TAG = imageTag()
        NAMESPACE = nameSpace()
        IMAGE_FULL = "${HARBOR_URL}/${PROJECT}/${APP_NAME}:${IMAGE_TAG}"
    }

    stages {
        //stage('Checkout') {
        //	steps {
        //		checkout scm
        //        //script {
        //		//	env.COMMIT_SHORT = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
        //        //}
        //    }
        //}

        stage('拉取代码并构建') {
            steps {
                checkout scm
                script {
                    container('maven') {
                        // 把全局 settings.xml 下载到工作区，路径注入变量
                        configFileProvider([configFile(fileId: "b46da426-c66a-400d-a254-68ce05001b12", variable: 'MAVEN_SETTINGS')]) {
                            // 执行 Maven 命令构建项目，并且设置 Maven 配置为刚刚创建的 Settings.xml 文件
                            sh "mvn -B -U -T 2C clean package deploy -Dmaven.test.skip=true -Dmaven.javadoc.skip=true -Dmaven.compile.fork=true -Dmaven.compiler.maxmem=2g -Pcarlos-private -s ${MAVEN_SETTINGS}"
                        }
                    }
                }
            }
        }


        /* ======== 1. 构建 & 上传镜像 ======== */
        stage('构建Docker镜像') {
            steps {
                script {
                    container('docker') {
                        // 唯一需要提前在 Jenkins 凭据里录好的 harbor 账号
                        //def HARBOR_CREDS = credentials('harbor')   // 类型：UsernamePassword
                        // 提供 Docker 环境，使用 Docker 工具来进行 Docker 镜像构建与推送
                        def customImage = docker.build("${IMAGE_FULL}", ".")
                        docker.withRegistry("https://${HARBOR_URL}", 'harbor') {
                            customImage.push()
                        }
                    }
                }
            }
        }

        stage('K8s部署') {
            steps {
                script {
                    // kubectl 镜像
                    container('kubectl') {
                        //直接使用项目内的deployment，这样方便到时候修改
                        def deploy = readFile encoding: "UTF-8", file: "./deploy/deploy.yaml"
                        // 替换部署文件中的变量，并将替换后的文本赋予 deployfile 变量
                        def deployfile = deploy.replaceAll("#APP_NAME", "${APP_NAME}")
                                .replaceAll("#APP_IMAGE_NAME", "${IMAGE_FULL}")
                                .replaceAll("#ENV_LIST", "${params.ENV}")
                                .replaceAll("#NAMESPACE", "${NAMESPACE}")
                        // 生成新的 Kubernetes 部署文件，内容为 deployfile 变量中的文本，文件名称为 "deploy.yaml"
                        writeFile encoding: 'UTF-8', file: './deploy.yaml', text: "${deployfile}"
                        // 输出新创建的部署 yaml 文件内容
                        sh "cat deploy.yaml"
                        // 执行 Kuberctl 命令进行部署操作
                        // sh "sleep 9999"
                        sh "kubectl apply -n ${NAMESPACE} -f deploy.yaml"
                        // 可选：等待滚动升级完成
                        sh "kubectl rollout status deployment/${APP_NAME} -n ${NAMESPACE} --timeout=300s"
                    }
                }
            }

        }
    }

    post {
        success {
            echo "✅ 部署成功：${APP_NAME}"
        }
        failure {
            echo "❌ 部署失败，请查看日志"
        }
    }
}
