{
  "groups": [
    {
      "name": "carlos.oauth2",
      "type": "com.carlos.auth.config.OAuth2Properties",
      "description": "Carlos OAuth2 统一认证配置",
      "sourceType": "com.carlos.auth.config.OAuth2Properties"
    },
    {
      "name": "carlos.oauth2.authorization-server",
      "type": "com.carlos.auth.config.OAuth2Properties$AuthorizationServerProperties",
      "description": "OAuth2 授权服务器配置",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$AuthorizationServerProperties"
    },
    {
      "name": "carlos.oauth2.jwt",
      "type": "com.carlos.auth.config.OAuth2Properties$JwtProperties",
      "description": "JWT Token 配置",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$JwtProperties"
    },
    {
      "name": "carlos.oauth2.security",
      "type": "com.carlos.auth.config.OAuth2Properties$SecurityProperties",
      "description": "安全配置",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$SecurityProperties"
    }
  ],
  "properties": [
    {
      "name": "carlos.oauth2.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用 OAuth2 功能",
      "defaultValue": true,
      "sourceType": "com.carlos.auth.config.OAuth2Properties"
    },
    {
      "name": "carlos.oauth2.authorization-server.enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用授权服务器（用于颁发 Token）",
      "defaultValue": false,
      "sourceType": "com.carlos.auth.config.OAuth2Properties$AuthorizationServerProperties"
    },
    {
      "name": "carlos.oauth2.authorization-server.access-token-time-to-live",
      "type": "java.time.Duration",
      "description": "访问令牌有效期",
      "defaultValue": "2h",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$AuthorizationServerProperties"
    },
    {
      "name": "carlos.oauth2.authorization-server.refresh-token-time-to-live",
      "type": "java.time.Duration",
      "description": "刷新令牌有效期",
      "defaultValue": "7d",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$AuthorizationServerProperties"
    },
    {
      "name": "carlos.oauth2.authorization-server.reuse-refresh-tokens",
      "type": "java.lang.Boolean",
      "description": "是否重用刷新令牌（false 更安全）",
      "defaultValue": false,
      "sourceType": "com.carlos.auth.config.OAuth2Properties$AuthorizationServerProperties"
    },
    {
      "name": "carlos.oauth2.jwt.issuer",
      "type": "java.lang.String",
      "description": "JWT Issuer 标识",
      "defaultValue": "http://localhost:8080",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$JwtProperties"
    },
    {
      "name": "carlos.oauth2.jwt.key-id",
      "type": "java.lang.String",
      "description": "密钥 ID",
      "defaultValue": "carlos-key",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$JwtProperties"
    },
    {
      "name": "carlos.oauth2.jwt.include-user-info",
      "type": "java.lang.Boolean",
      "description": "Token 中是否包含用户信息",
      "defaultValue": true,
      "sourceType": "com.carlos.auth.config.OAuth2Properties$JwtProperties"
    },
    {
      "name": "carlos.oauth2.security.password-encoder",
      "type": "java.lang.String",
      "description": "密码编码器类型（bcrypt、sm4）",
      "defaultValue": "bcrypt",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$SecurityProperties"
    },
    {
      "name": "carlos.oauth2.security.token-storage",
      "type": "java.lang.String",
      "description": "Token 存储方式（memory、redis、jdbc）",
      "defaultValue": "memory",
      "sourceType": "com.carlos.auth.config.OAuth2Properties$SecurityProperties"
    }
  ],
  "hints": [
    {
      "name": "carlos.oauth2.security.password-encoder",
      "values": [
        {
          "value": "bcrypt",
          "description": "BCrypt 算法（推荐）"
        },
        {
          "value": "sm4",
          "description": "国密 SM4 算法"
        }
      ]
    },
    {
      "name": "carlos.oauth2.security.token-storage",
      "values": [
        {
          "value": "memory",
          "description": "内存存储（仅开发测试）"
        },
        {
          "value": "redis",
          "description": "Redis 存储（推荐）"
        },
        {
          "value": "jdbc",
          "description": "数据库存储"
        }
      ]
    }
  ]
}
