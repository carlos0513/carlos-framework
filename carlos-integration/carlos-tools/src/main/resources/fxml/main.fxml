<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.carlos.fx.common.controller.MainController"
            prefHeight="800.0" prefWidth="1200.0">

    <!-- Left Navigation Drawer -->
    <left>
        <VBox styleClass="navigation-drawer" prefWidth="280" spacing="10" style="-fx-padding: 20;">
            <Label text="Carlos Tools" styleClass="title-large" style="-fx-padding: 0 0 20 0;"/>
            <ListView fx:id="toolListView" styleClass="navigation-list-view" VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>

    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content-pane"/>
    </center>

</BorderPane>
