<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.carlos.fx.encrypt.EncryptToolController"
      spacing="20" style="-fx-padding: 20;">

    <Label text="加密工具" styleClass="title-large"/>
    <Separator/>

    <!-- Step 1: Database Connection -->
    <VBox spacing="10" styleClass="card">
        <Label text="步骤 1: 数据库连接" styleClass="title-medium"/>

        <GridPane styleClass="form-grid" hgap="15" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
                <ColumnConstraints minWidth="120" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="数据库类型:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <ComboBox fx:id="databaseTypeCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="主机地址:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="hostField" promptText="localhost" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

            <Label text="端口:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="portField" promptText="3306" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="数据库名:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="databaseField" promptText="database_name" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Label text="用户名:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="usernameField" promptText="root" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="密码:" styleClass="form-label" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            <PasswordField fx:id="passwordField" promptText="password" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
        </GridPane>

        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="testConnectionButton" text="测试连接" styleClass="secondary-button"/>
            <Button fx:id="loadTablesButton" text="加载表信息" styleClass="primary-button"/>
        </HBox>
    </VBox>

    <!-- Step 2: Table and Field Selection -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="步骤 2: 选择表和字段" styleClass="title-medium"/>

        <TreeView fx:id="tableTreeView" VBox.vgrow="ALWAYS" minHeight="200"/>

        <Label text="提示: 展开表节点，勾选需要加密/解密的字段" style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>
    </VBox>

    <!-- Step 3: Encryption Configuration -->
    <VBox spacing="10" styleClass="card">
        <Label text="步骤 3: 加密配置" styleClass="title-medium"/>

        <GridPane styleClass="form-grid" hgap="15" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="120"/>
                <ColumnConstraints hgrow="ALWAYS"/>
            </columnConstraints>

            <Label text="SM4密钥:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="sm4KeyField" promptText="32位密钥 (例如: 0123456789abcdef0123456789abcdef)" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

            <Label text="SM4向量:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="sm4IvField" promptText="32位向量 (例如: 0123456789abcdef0123456789abcdef)" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="操作类型:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <HBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <RadioButton fx:id="encryptRadio" text="加密"/>
                <RadioButton fx:id="decryptRadio" text="解密"/>
            </HBox>

            <Label text="批次大小:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="batchSizeField" promptText="5000" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        </GridPane>

        <Label text="提示: 批次大小决定每次处理的记录数，建议5000条" style="-fx-text-fill: #757575; -fx-font-size: 12px;"/>

        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="executeButton" text="执行操作" styleClass="success-button"/>
        </HBox>

        <ProgressBar fx:id="progressBar" prefWidth="Infinity" progress="0"/>
        <Label fx:id="statusLabel" style="-fx-text-fill: #1976d2;"/>
    </VBox>

    <!-- Operation Log -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <Label text="操作日志" styleClass="title-medium"/>

        <TextArea fx:id="logArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS" minHeight="150"
                  style="-fx-font-family: 'Consolas', 'Courier New', monospace; -fx-font-size: 12px;"/>
    </VBox>

</VBox>
