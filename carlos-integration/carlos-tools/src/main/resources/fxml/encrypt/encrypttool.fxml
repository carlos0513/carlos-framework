<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/11.0.14-internal" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.carlos.fx.encrypt.EncryptToolController">

    <Label styleClass="title-large" text="加密工具" />
    <Separator />

    <!-- Step 1: Database Connection -->
    <VBox spacing="10" styleClass="card">
        <Label styleClass="title-medium" text="步骤 1: 数据库连接" />

        <GridPane hgap="15" styleClass="form-grid" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="120" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints minWidth="120" prefWidth="120" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label styleClass="form-label" text="数据库类型:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="databaseTypeCombo" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="form-label" text="主机地址:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="hostField" promptText="localhost" GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <Label styleClass="form-label" text="端口:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="portField" prefWidth="200" promptText="3306" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label styleClass="form-label" text="数据库名:" GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <TextField fx:id="databaseField" promptText="database_name" GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <Label styleClass="form-label" text="用户名:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="usernameField" promptText="root" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label styleClass="form-label" text="密码:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <PasswordField fx:id="passwordField" promptText="password" GridPane.columnIndex="3" GridPane.rowIndex="2" />
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="testConnectionButton" styleClass="secondary-button" text="测试连接" />
            <Button fx:id="loadTablesButton" styleClass="primary-button" text="加载表信息" />
        </HBox>
    </VBox>

    <!-- Step 2: Table and Field Selection -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <Label styleClass="title-medium" text="步骤 2: 选择表和字段" />

        <TreeView fx:id="tableTreeView" minHeight="200" VBox.vgrow="ALWAYS" />

        <Label style="-fx-text-fill: #757575; -fx-font-size: 12px;" text="提示: 展开表节点，勾选需要加密/解密的字段" />
    </VBox>

    <!-- Step 3: Encryption Configuration -->
    <VBox spacing="10" styleClass="card">
        <Label styleClass="title-medium" text="步骤 3: 加密配置" />

        <GridPane hgap="15" styleClass="form-grid" vgap="12">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="120" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label styleClass="form-label" text="SM4密钥:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="sm4KeyField" promptText="32位密钥 (例如: 0123456789abcdef0123456789abcdef)" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label styleClass="form-label" text="SM4向量:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="sm4IvField" promptText="32位向量 (例如: 0123456789abcdef0123456789abcdef)" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label styleClass="form-label" text="操作类型:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <HBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="2">
                <RadioButton fx:id="encryptRadio" text="加密" />
                <RadioButton fx:id="decryptRadio" text="解密" />
            </HBox>

            <Label styleClass="form-label" text="批次大小:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <TextField fx:id="batchSizeField" prefWidth="200" promptText="5000" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>

        <Label style="-fx-text-fill: #757575; -fx-font-size: 12px;" text="提示: 批次大小决定每次处理的记录数，建议5000条" />

        <HBox spacing="10" style="-fx-padding: 10 0 0 0;">
            <Button fx:id="executeButton" styleClass="success-button" text="执行操作" />
        </HBox>

        <ProgressBar fx:id="progressBar" prefWidth="Infinity" progress="0" />
        <Label fx:id="statusLabel" style="-fx-text-fill: #1976d2;" />
    </VBox>

    <!-- Operation Log -->
    <VBox spacing="10" styleClass="card" VBox.vgrow="ALWAYS">
        <Label styleClass="title-medium" text="操作日志" />

        <TextArea fx:id="logArea" editable="false" minHeight="150" style="-fx-font-family: 'Consolas', 'Courier New', monospace; -fx-font-size: 12px;" wrapText="true" VBox.vgrow="ALWAYS" />
    </VBox>

</VBox>
