<?xml version="1.0" encoding="UTF-8"?>
<!--模板配置文件
 1.配置模板的基本信息，下拉展示和GUI介绍；
 2.当模板的文件名和对应文件的文件名不一致时，需要配置映射关系

-->
<templates>
    <name>微服务Elasticsearch</name>
    <describe>elasticsearch</describe>
    <!--逻辑删除字段-->
    <logicDeleteFields>
        <name>is_deleted</name>
        <name>is_delete</name>
        <name>deleted</name>
        <name>delete</name>
        <name>delete_flag</name>
        <name>del_flag</name>
    </logicDeleteFields>
    <!--乐观锁版本字段-->
    <versionFields>
        <name>version</name>
    </versionFields>
    <!--共同字段-->
    <commonFields>
        <name>create_user</name>
        <name>createUser</name>
        <name>create_by</name>
        <name>createBy</name>
        <name>create_time</name>
        <name>createTime</name>
        <name>create_date</name>
        <name>createDate</name>

        <name>update_user</name>
        <name>updateUser</name>
        <name>update_by</name>
        <name>updateBy</name>
        <name>update_time</name>
        <name>updateTime</name>
        <name>update_date</name>
        <name>updateDate</name>

        <name>modify_user</name>
        <name>modifyUser</name>
        <name>modify_by</name>
        <name>modifyBy</name>
        <name>modify_time</name>
        <name>modifyTime</name>
        <name>modify_date</name>
        <name>modifyDate</name>
    </commonFields>


</templates>
