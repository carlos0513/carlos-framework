{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(for:*)",
      "Bash(do if [ -f \"$dir/pom.xml\" ])",
      "Bash(then echo \"Processing $dir/pom.xml\")",
      "Bash(fi:*)",
      "Bash(done)",
      "Bash(do if [[ \"$dir\" != \"carlos-core/\" ]])",
      "Bash(then echo \"Processing $dir\")",
      "Bash(find:*)",
      "Bash(while:*)",
      "Bash(do if [ -f \"$f\" ])",
      "Bash(then sed -i 's/carlos:/carlos:/g' \"$f\")",
      "Bash(mvn compile:*)",
      "Bash(do pom=\"$sub/pom.xml\")",
      "Bash(if [ -f \"$pom\" ])",
      "Bash(then sed -i 's|<groupId>com\\\\.carlos\\\\.license</groupId>|<groupId>com.carlos.license</groupId>|g' \"$pom\")",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(xargs sed:*)",
      "Bash(mvn install:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mvn clean compile:*)",
      "Bash(mvn help:effective-pom:*)",
      "Bash(do if [ -d \"$dir\" ])",
      "Bash(then if [ -f \"$dir/src/main/resources/META-INF/spring/org.springframework.boot.autoconfigure.AutoConfiguration.imports\" ])",
      "Bash(then echo \"$dir: HAS AutoConfiguration.imports\")",
      "Bash(else echo \"$dir: NO AutoConfiguration.imports\")",
      "Bash(then if [ ! -f \"$dir/src/main/resources/META-INF/spring/org.springframework.boot.autoconfigure.AutoConfiguration.imports\" ])",
      "Bash(then echo \"$dir\")",
      "Bash(git mv:*)",
      "Bash(mvn clean install:*)"
    ],
    "deny": [
      "Read(**/test-classes/**)",
      "Read(**/.idea/**)",
      "Read(**/.git/**)",
      "Read(**/target/**)",
      "Read(**/node_modules/**)",
      "Read(**/*.iml)",
      "Read(**/rebel.xml)",
      "Read(**/.flattened-pom.xml)",
      "Read(**/.gitignore)",
      "Read(**/*.log)"
    ]
  },
  "max_tokens": 8000,
  "compact_threshold": 0.8
}
