{
  "permissions": {
    "allow": [
      "Bash(mvn clean install*)",
      "Bash(mvn clean deploy*)",
      "Bash(mvn test*)",
      "Bash(mvn verify*)",
      "Bash(mvn versions:*)",
      "Bash(mvn help:*)",
      "Bash(mvn dependency:*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git pull*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)"
    ]
  }
}
