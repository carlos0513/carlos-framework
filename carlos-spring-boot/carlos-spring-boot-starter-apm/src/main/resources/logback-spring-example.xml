<?xml version="1.0" encoding="UTF-8"?>
<!--
  Carlos Framework 日志配置示例 - 整合 Request ID 和 Trace ID

  使用说明：
  1. 将此文件复制到业务模块的 src/main/resources/logback-spring.xml
  2. 根据实际需求调整日志级别和输出路径
  3. 支持 MDC 变量：%X{requestId}, %X{traceId}, %X{spanId}, %X{tid}

  MDC 变量说明：
  - requestId: 业务自定义请求ID（兼容原有实现）
  - traceId:  Micrometer Tracing 链路追踪ID
  - spanId:   Micrometer Tracing 跨度ID
  - tid:      SkyWalking Trace ID
-->
<configuration scan="true" scanPeriod="60 seconds" debug="false">

  <!-- ==================== 属性定义 ==================== -->
  <!-- 日志输出路径 -->
  <property name="LOG_PATH" value="${LOG_PATH:-./logs}"/>
  <property name="APP_NAME" value="${spring.application.name:-carlos-app}"/>

  <!-- 日志格式定义 -->
  <!--
    格式说明：
    %d{yyyy-MM-dd HH:mm:ss.SSS} - 日期时间
    [%thread]                    - 线程名
    %-5level                     - 日志级别（左对齐5字符）
    [%X{requestId}]              - 业务 Request ID（原有自定义ID）
    [%X{traceId}-%X{spanId}]     - 链路追踪 ID（Micrometer Tracing）
    %logger{36}                  - Logger 名（最多36字符）
    %msg%n                       - 消息 + 换行

    示例输出：
    2025-03-26 14:30:25.123 [http-nio-8080-exec-1] INFO  [a1b2c3d4e5f67890] [abc123def4567890-xyz789abc123def4] c.c.s.controller.UserController - 用户查询成功
  -->
  <property name="CONSOLE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId:-}] [%X{traceId:-}-%X{spanId:-}] %logger{36} - %msg%n"/>

  <property name="FILE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{requestId:-}] [%X{traceId:-}-%X{spanId:-}] %logger{36} - %msg%n"/>

  <!-- SkyWalking 专用的日志格式（包含 SkyWalking Trace ID） -->
  <property name="SW_FILE_PATTERN"
            value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{tid:-}] [%X{requestId:-}] %logger{36} - %msg%n"/>

  <!-- ==================== Appender 定义 ==================== -->

  <!-- 控制台输出 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>${CONSOLE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- 普通文件输出（按天滚动） -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/${APP_NAME}.log</file>
    <encoder>
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>10GB</totalSizeCap>
      <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
        <maxFileSize>100MB</maxFileSize>
      </timeBasedFileNamingAndTriggeringPolicy>
    </rollingPolicy>
  </appender>

  <!-- 错误日志单独输出 -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>${LOG_PATH}/${APP_NAME}-error.log</file>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>ERROR</level>
    </filter>
    <encoder>
      <pattern>${FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
    <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
      <fileNamePattern>${LOG_PATH}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxHistory>30</maxHistory>
      <totalSizeCap>5GB</totalSizeCap>
      <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
        <maxFileSize>100MB</maxFileSize>
      </timeBasedFileNamingAndTriggeringPolicy>
    </rollingPolicy>
  </appender>

  <!-- 异步 Appender（提升性能，减少日志 I/O 对业务的影响） -->
  <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
    <!-- 队列大小，根据内存和并发量调整 -->
    <queueSize>512</queueSize>
    <!-- 队列剩余容量低于此值时丢弃 TRACE/DEBUG/INFO 级别日志，0 表示不丢弃 -->
    <discardingThreshold>0</discardingThreshold>
    <!-- 队列满时是否阻塞，设置为 true 不阻塞，避免影响业务 -->
    <neverBlock>true</neverBlock>
    <!-- 最大刷新时间（毫秒） -->
    <maxFlushTime>1000</maxFlushTime>
    <appender-ref ref="FILE"/>
  </appender>

  <!-- SkyWalking 集成 Appender（如果使用 SkyWalking） -->
  <appender name="SKYWALKING" class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.log.GRPCLogClientAppender">
    <encoder>
      <pattern>${SW_FILE_PATTERN}</pattern>
      <charset>UTF-8</charset>
    </encoder>
  </appender>

  <!-- ==================== 日志级别配置 ==================== -->

  <!-- Spring 框架 -->
  <logger name="org.springframework" level="INFO"/>
  <logger name="org.springframework.web" level="INFO"/>
  <logger name="org.springframework.jdbc" level="DEBUG"/>

  <!-- 数据源和 MyBatis -->
  <logger name="com.alibaba.druid" level="INFO"/>
  <logger name="com.baomidou.mybatisplus" level="INFO"/>

  <!-- 服务调用 -->
  <logger name="org.springframework.web.client.RestTemplate" level="DEBUG"/>
  <logger name="org.springframework.web.servlet.DispatcherServlet" level="DEBUG"/>

  <!-- Feign -->
  <logger name="feign" level="INFO"/>
  <logger name="com.carlos.apm.feign" level="DEBUG"/>

  <!-- 业务代码 -->
  <logger name="com.carlos" level="DEBUG"/>

  <!-- ==================== Root 配置 ==================== -->
  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="ASYNC_FILE"/>
    <appender-ref ref="ERROR_FILE"/>
    <!-- 如需 SkyWalking 日志上报，取消下面注释 -->
    <!-- <appender-ref ref="SKYWALKING"/> -->
  </root>

  <!-- ==================== 多环境配置 ==================== -->
  <!-- 开发环境：控制台输出详细日志 -->
  <springProfile name="dev,local">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
    </root>
    <logger name="com.carlos" level="DEBUG"/>
  </springProfile>

  <!-- 测试环境：文件 + 控制台 -->
  <springProfile name="test">
    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="ASYNC_FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>

  <!-- 生产环境：仅文件输出，关闭控制台 -->
  <springProfile name="prod">
    <root level="WARN">
      <appender-ref ref="ASYNC_FILE"/>
      <appender-ref ref="ERROR_FILE"/>
      <appender-ref ref="SKYWALKING"/>
    </root>
    <logger name="com.carlos" level="INFO"/>
  </springProfile>

</configuration>
