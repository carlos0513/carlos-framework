    <module>carlos-sample-oss</module>

    <!-- Redis 多级缓存样例 -->
    <module>carlos-sample-redis</module>

    <!-- 短信服务样例 -->
    <module>carlos-sample-sms</module>

    <!-- 分布式 ID 样例 -->
    <module>carlos-sample-snowflake</module>

    <!-- Web 基础样例 -->
    <module>carlos-sample-web</module>

    <!-- Spring Cloud 微服务样例 -->
    <module>carlos-sample-cloud</module>
