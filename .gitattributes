# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.java text diff=java
*.kt text diff=kotlin
*.groovy text
*.scala text
*.gradle text
*.xml text
*.yml text
*.yaml text
*.properties text
*.json text

# Documentation
*.md text diff=markdown
*.txt text
*.rst text
*.adoc text
READ* text

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=lf

# Config files
.editorconfig text
.gitattributes text
.gitignore text
.gitconfig text

# Binary files
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.tar.gz binary
*.tar.bz2 binary
*.tar.xz binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rar binary

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text
*.webp binary

# Fonts
*.ttf binary
*.eot binary
*.otf binary
*.woff binary
*.woff2 binary

# Office documents
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.ppt binary
*.pptx binary
*.pdf binary

# Executables
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Compiled files
*.class binary
