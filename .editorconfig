root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

[*.{xml,html}]
indent_size = 2

[*.{json,js,ts}]
indent_size = 2

[*.properties]
indent_size = 2

[*.sh]
end_of_line = lf

[*.bat]
end_of_line = crlf

[*.cmd]
end_of_line = crlf

[COMMIT_EDITMSG]
max_line_length = 72
